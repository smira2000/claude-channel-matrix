# Matrix homeserver URL
MATRIX_HOMESERVER=https://matrix.example.com

# Bot account credentials
MATRIX_USER_ID=@botname:example.com
MATRIX_ACCESS_TOKEN=syt_...

# Directory for bot state (access list, etc.)
MATRIX_STATE_DIR=~/.claude/channels/matrix

# For running tests only (not needed in production)
# MATRIX_TEST_USER=testuser
# MATRIX_TEST_PASSWORD=testpassword
